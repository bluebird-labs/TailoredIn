---
title: TailoredIn — Domain Entities & Relationships
---

classDiagram
    direction TB

    %% ──────────────────────────────────────────────
    %%  Profile Subdomain
    %% ──────────────────────────────────────────────

    class Profile {
        <<AggregateRoot>>
        +string email
        +string firstName
        +string lastName
        +string? about
        +string? phone
        +string? githubUrl
        +string? linkedinUrl
        +string? websiteUrl
        +string? location
        +fullName()
    }

    class Application {
        <<AggregateRoot>>
        +string profileId
        +string companyId
        +ApplicationStatus status
        +string? jobDescriptionId
        +string? notes
        +Date appliedAt
        +setStatus()
    }

    class Education {
        <<AggregateRoot>>
        +string profileId
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? location
        +string? honors
        +number ordinal
        +boolean hiddenByDefault
    }

    class Experience {
        <<AggregateRoot>>
        +string profileId
        +string title
        +string companyName
        +string? companyWebsite
        +string? companyAccent
        +string? companyId
        +string location
        +string startDate
        +string endDate
        +string? summary
        +number ordinal
        +addAccomplishment()
        +removeAccomplishment()
        +findAccomplishmentOrFail()
        +linkCompany()
        +unlinkCompany()
        +syncAccomplishments()
    }

    class ExperienceGenerationOverride {
        <<AggregateRoot>>
        +string experienceId
        +number bulletMin
        +number bulletMax
        +updateBulletRange()
    }

    class GenerationSettings {
        <<AggregateRoot>>
        +string profileId
        +ModelTier modelTier
        +number bulletMin
        +number bulletMax
        +updateModelTier()
        +updateBulletRange()
        +setPrompt()
        +removePrompt()
        +getPrompt()
    }

    class ResumeContent {
        <<AggregateRoot>>
        +string profileId
        +string jobDescriptionId
        +string headline
        +ResumeExperience[] experiences
        +string[] hiddenEducationIds
        +string prompt
        +Record<string, unknown>? schema
        +withExperienceHiddenBullets()
        +withHiddenEducationIds()
    }

    class ApplicationStatus {
        <<enumeration>>
        DRAFT · APPLIED · SCREENING
        INTERVIEWING · OFFERED · REJECTED
        WITHDRAWN · ACCEPTED · ARCHIVED
    }

    class ResumeExperience {
        <<ValueObject>>
        +string experienceId
        +string summary
        +string[] bullets
        +number[] hiddenBulletIndices
    }

    Profile "1" --> "*" GenerationSettings : has
    Profile "1" --> "*" ResumeContent : has
    ResumeContent "1" *-- "*" ResumeExperience : contains
    Experience "1" --> "*" ExperienceGenerationOverride : has
    Profile "1" --> "*" Application : has
    Application --> ApplicationStatus
    Profile "1" --> "*" Education : has
    Profile "1" --> "*" Experience : has

    %% ──────────────────────────────────────────────
    %%  Company Subdomain
    %% ──────────────────────────────────────────────

    class Company {
        <<AggregateRoot>>
        +string name
        +string domainName
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType businessType
        +Industry industry
        +CompanyStage stage
        +CompanyStatus status
        +setDomainName()
        +setLinkedinLink()
        +setWebsite()
        +setBusinessType()
        +setIndustry()
        +setStage()
        +setStatus()
    }

    class JobDescription {
        <<AggregateRoot>>
        +string companyId
        +string title
        +string description
        +string? url
        +string? location
        +number? salaryMin
        +number? salaryMax
        +string? salaryCurrency
        +JobLevel level
        +LocationType locationType
        +JobSource source
        +Date? postedAt
        +string? rawText
        +string[]? soughtHardSkills
        +string[]? soughtSoftSkills
        +Buffer? resumePdf
        +string? resumePdfTheme
        +salaryRange()
    }

    class CompanyStatus {
        <<enumeration>>
        RUNNING · ACQUIRED · MERGED
        DEFUNCT · STEALTH · UNKNOWN
    }

    class JobSource {
        <<enumeration>>
        LINKEDIN · PARAFORM · GREENHOUSE
        LEVER · WORKDAY · WELLFOUND
        ASHBY · COMPANY_WEBSITE · REFERRAL
        UPLOAD
    }

    class LocationType {
        <<enumeration>>
        REMOTE · REMOTE_FIRST · HYBRID
        FLEXIBLE · ONSITE · UNKNOWN
    }

    JobDescription "1" --> "*" ResumeContent : has
    Company "1" --> "*" JobDescription : has
    JobDescription --> LocationType
    JobDescription --> JobSource
    Company "1" --> "*" Application : has
    JobDescription "1" --> "*" Application : has
    Company "1" --> "*" Experience : has
    Company --> CompanyStatus

    %% ──────────────────────────────────────────────
    %%  Enums & Types
    %% ──────────────────────────────────────────────

    class AccomplishmentSnapshot {
        <<ValueObject>>
        +string title
        +string narrative
    }

    class BlockLayout {
        <<ValueObject>>
        +number lineCount
        +number[] pageNumbers
    }

    class BusinessType {
        <<enumeration>>
        B2B · B2C · B2B2C
        B2G · D2C · MARKETPLACE
        PLATFORM · ENTERPRISE · UNKNOWN
    }

    class CacheTier {
        <<enumeration>>
        SYSTEM_STABLE · PROFILE_STABLE · SESSION_STABLE
        REQUEST_VARIABLE
    }

    class CompanySnapshot {
        <<ValueObject>>
        +string id
        +string name
        +string? description
        +Industry industry
        +CompanyStage stage
        +BusinessType businessType
    }

    class CompanyStage {
        <<enumeration>>
        PRE_SEED · SEED · SERIES_A
        SERIES_B · SERIES_C · SERIES_D_PLUS
        LATE_STAGE · IPO · PUBLIC
        PRIVATE_EQUITY · BOOTSTRAPPED · UNKNOWN
    }

    class EducationSnapshot {
        <<ValueObject>>
        +string id
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? honors
    }

    class ExperienceSnapshot {
        <<ValueObject>>
        +string id
        +string title
        +string companyName
        +string? summary
        +AccomplishmentSnapshot[] accomplishments
        +string startDate
        +string endDate
        +string location
        +number bulletMin
        +number bulletMax
        +string? companyId
    }

    class GenerationContext {
        <<ValueObject>>
        +ProfileSnapshot profile
        +JDSnapshot jobDescription
        +ExperienceSnapshot[] experiences
        +CompanySnapshot[] companies
        +EducationSnapshot[] education
        +SettingsSnapshot settings
        +string? userInstructions
    }

    class GenerationScope {
        <<enumeration>>
        RESUME · HEADLINE · EXPERIENCE
        EXPERIENCE_SUMMARY · BULLET
    }

    class Industry {
        <<enumeration>>
        AUTOMOBILE · CYBERSECURITY · FINANCE
        HEALTHCARE · EDUCATION · E_COMMERCE
        REAL_ESTATE · MEDIA · LOGISTICS
        ENERGY · AGRICULTURE · TRAVEL
        FOOD · LEGAL · HR_TECH
        MARTECH · SOFTWARE · AI
        GAMING · TELECOM · INSURANCE
        RETAIL · CONSTRUCTION · GOVERNMENT
        BIOTECH · PHARMA · AEROSPACE_DEFENSE
        MANUFACTURING · ENTERTAINMENT · NONPROFIT
        CONSULTING · SEMICONDUCTOR · CLIMATE_TECH
        FINTECH · CRYPTO_WEB3 · TRANSPORTATION
        UNKNOWN
    }

    class JDSnapshot {
        <<ValueObject>>
        +string id
        +string title
        +string description
        +string? rawText
        +string[] soughtHardSkills
        +string[] soughtSoftSkills
        +JobLevel? level
    }

    class JobLevel {
        <<enumeration>>
        INTERNSHIP · ENTRY_LEVEL · ASSOCIATE
        SENIOR · STAFF · PRINCIPAL
        MANAGER · DIRECTOR · VP
        EXECUTIVE · UNKNOWN
    }

    class LayoutAnalysis {
        <<ValueObject>>
        +number totalPages
        +object header
        +object experiences
        +BlockLayout[] education
        +BlockLayout[] skills
    }

    class ModelTier {
        <<enumeration>>
        FAST · BALANCED · BEST
    }

    class ProfileSnapshot {
        <<ValueObject>>
        +string id
        +string firstName
        +string lastName
        +string? about
        +string? location
    }

    class ResumeTemplate {
        <<ValueObject>>
        +string id
        +string pageSize
        +object margins
        +number bodyFontSizePt
        +number lineHeightEm
        +number headerFontSizePt
        +number sectionSpacingPt
        +number entrySpacingPt
    }

    class SalaryRange {
        <<ValueObject>>
        +min()
        +max()
        +currency()
        +toJSON()
    }

    class SettingsSnapshot {
        <<ValueObject>>
        +ModelTier modelTier
        +number bulletMin
        +number bulletMax
        +ReadonlyMap<GenerationScope, string> adminPrompts
    }

    GenerationSettings --> ModelTier
    JobDescription --> JobLevel
    Company --> BusinessType
    Company --> Industry
    Company --> CompanyStage
    LayoutAnalysis "1" *-- "*" BlockLayout : contains
    JDSnapshot --> JobLevel
    ExperienceSnapshot "1" *-- "*" AccomplishmentSnapshot : contains
    CompanySnapshot --> Industry
    CompanySnapshot --> CompanyStage
    CompanySnapshot --> BusinessType
    SettingsSnapshot --> ModelTier
    GenerationContext *-- ProfileSnapshot
    GenerationContext *-- JDSnapshot
    GenerationContext "1" *-- "*" ExperienceSnapshot : contains
    GenerationContext "1" *-- "*" CompanySnapshot : contains
    GenerationContext "1" *-- "*" EducationSnapshot : contains
    GenerationContext *-- SettingsSnapshot

