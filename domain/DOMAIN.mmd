---
title: TailoredIn — Domain Entities & Relationships
---

classDiagram
    direction TB

    %% ──────────────────────────────────────────────
    %%  Profile Subdomain
    %% ──────────────────────────────────────────────

    class Profile {
        <<AggregateRoot>>
        +ProfileId id
        +string email
        +string firstName
        +string lastName
        +string? about
        +string? phone
        +string? githubUrl
        +string? linkedinUrl
        +string? websiteUrl
        +string? location
        +fullName()
    }

    class Accomplishment {
        <<Entity>>
        +AccomplishmentId id
        +string experienceId
        +string title
        +string narrative
        +number ordinal
        +update()
    }

    class Application {
        <<AggregateRoot>>
        +ApplicationId id
        +string profileId
        +string companyId
        +ApplicationStatus status
        +string? jobDescriptionId
        +string? notes
        +Date appliedAt
        +setStatus()
    }

    class Education {
        <<AggregateRoot>>
        +EducationId id
        +string profileId
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? location
        +string? honors
        +number ordinal
    }

    class Experience {
        <<AggregateRoot>>
        +ExperienceId id
        +string profileId
        +string title
        +string companyName
        +string? companyWebsite
        +string? companyId
        +string location
        +string startDate
        +string endDate
        +string? summary
        +number ordinal
        +Accomplishment[] accomplishments
        +addAccomplishment()
        +removeAccomplishment()
        +findAccomplishmentOrFail()
        +linkCompany()
        +unlinkCompany()
        +syncAccomplishments()
    }

    class ResumeContent {
        <<AggregateRoot>>
        +ResumeContentId id
        +string profileId
        +string jobDescriptionId
        +string headline
        +ResumeExperience[] experiences
        +string[] hiddenEducationIds
        +string prompt
        +Record<string, unknown>? schema
        +withExperienceBulletCount()
        +withHiddenEducationIds()
    }

    class ApplicationStatus {
        <<enumeration>>
        DRAFT · APPLIED · INTERVIEWING
        OFFERED · REJECTED · WITHDRAWN
        ACCEPTED
    }

    class ResumeExperience {
        <<ValueObject>>
        +string experienceId
        +string summary
        +string[] bullets
        +number? displayedBulletCount
    }

    Profile "1" --> "*" ResumeContent : has
    ResumeContent "1" *-- "*" ResumeExperience : contains
    Profile "1" --> "*" Application : has
    Application --> ApplicationStatus
    Profile "1" --> "*" Education : has
    Profile "1" --> "*" Experience : has
    Experience "1" *-- "*" Accomplishment : contains

    %% ──────────────────────────────────────────────
    %%  Company Subdomain
    %% ──────────────────────────────────────────────

    class Company {
        <<AggregateRoot>>
        +CompanyId id
        +string name
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType? businessType
        +Industry? industry
        +CompanyStage? stage
        +CompanyStatus? status
        +setWebsite()
        +setBusinessType()
        +setIndustry()
        +setStage()
        +setStatus()
    }

    class JobDescription {
        <<AggregateRoot>>
        +JobDescriptionId id
        +string companyId
        +string title
        +string description
        +string? url
        +string? location
        +SalaryRange? salaryRange
        +JobLevel? level
        +LocationType? locationType
        +JobSource source
        +Date? postedAt
        +string? rawText
        +string[]? soughtHardSkills
        +string[]? soughtSoftSkills
        +Uint8Array? resumePdf
        +string? resumePdfTheme
    }

    class BusinessType {
        <<enumeration>>
        B2B · B2C · B2B2C
        B2G · D2C · MARKETPLACE
        PLATFORM
    }

    class CompanyStage {
        <<enumeration>>
        SEED · SERIES_A · SERIES_B
        SERIES_C · SERIES_D_PLUS · GROWTH
        PUBLIC · BOOTSTRAPPED
    }

    class CompanyStatus {
        <<enumeration>>
        RUNNING · ACQUIRED · DEFUNCT
    }

    class Industry {
        <<enumeration>>
        AUTOMOBILE · SECURITY · FINANCE
        HEALTHCARE · EDUCATION · E_COMMERCE
        REAL_ESTATE · MEDIA · LOGISTICS
        ENERGY · AGRICULTURE · TRAVEL
        FOOD · LEGAL · HR
        MARKETING · SAAS · AI_ML
        GAMING · TELECOM · INSURANCE
        RETAIL · CONSTRUCTION · GOVERNMENT
    }

    class JobLevel {
        <<enumeration>>
        INTERNSHIP · ENTRY_LEVEL · ASSOCIATE
        MID_SENIOR · DIRECTOR · EXECUTIVE
    }

    class JobSource {
        <<enumeration>>
        LINKEDIN · PARAFORM · GREENHOUSE
        UPLOAD
    }

    class LocationType {
        <<enumeration>>
        REMOTE · HYBRID · ONSITE
    }

    class SalaryRange {
        <<ValueObject>>
        +min()
        +max()
        +currency()
    }

    JobDescription "1" --> "*" ResumeContent : has
    Company "1" --> "*" JobDescription : has
    JobDescription *-- SalaryRange
    JobDescription --> JobLevel
    JobDescription --> LocationType
    JobDescription --> JobSource
    Company "1" --> "*" Application : has
    JobDescription "1" --> "*" Application : has
    Company "1" --> "*" Experience : has
    Company --> BusinessType
    Company --> Industry
    Company --> CompanyStage
    Company --> CompanyStatus

    %% ──────────────────────────────────────────────
    %%  Enums & Types
    %% ──────────────────────────────────────────────

    class BlockLayout {
        <<ValueObject>>
        +number lineCount
        +number[] pageNumbers
    }

    class LayoutAnalysis {
        <<ValueObject>>
        +number totalPages
        +object header
        +object experiences
        +BlockLayout[] education
        +BlockLayout[] skills
    }

    class ResumeTemplate {
        <<ValueObject>>
        +string id
        +string pageSize
        +object margins
        +number bodyFontSizePt
        +number lineHeightEm
        +number headerFontSizePt
        +number sectionSpacingPt
        +number entrySpacingPt
    }

    LayoutAnalysis "1" *-- "*" BlockLayout : contains

