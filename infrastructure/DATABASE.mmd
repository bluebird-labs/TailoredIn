---
title: TailoredIn — Database ERD (PostgreSQL)
---

erDiagram

    %% ──────────────────────────────────────────────
    %%  Tables
    %% ──────────────────────────────────────────────

    accomplishments {
        uuid id PK
        uuid experience_id FK
        text title "default: empty"
        text narrative "default: empty"
        integer ordinal "default: 0"
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
    }

    applications {
        uuid id PK
        uuid profile_id FK
        uuid company_id FK
        uuid job_description_id FK "nullable"
        application_status status "default: draft"
        text notes "nullable"
        timestamp applied_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
    }

    archetype_tag_weights {
        uuid id PK
        uuid archetype_id FK "unique"
        uuid tag_id UK
        numeric weight
    }

    archetypes {
        uuid id PK
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        uuid profile_id FK
        text key
        text label
        uuid headline_id "nullable"
        json content_selection "default: {}"
        text headline_text "default: empty"
    }

    companies {
        uuid id PK
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        text name
        text logo_url "nullable"
        text linkedin_link UK "nullable"
        text website "nullable"
        business_type business_type "default: unknown"
        industry industry "default: unknown"
        company_stage stage "default: unknown"
        text description "nullable"
        company_status status "default: unknown"
        text domain_name
    }

    educations {
        uuid id PK
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        uuid profile_id FK
        text degree_title
        text institution_name
        integer graduation_year
        text location "nullable"
        text honors "nullable"
        integer ordinal "default: 0"
        boolean hidden_by_default "default: false"
    }

    experiences {
        uuid id PK
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        uuid profile_id FK
        text title
        text company_name
        text company_website "nullable"
        text location "default: empty"
        text start_date
        text end_date
        text summary "nullable"
        integer ordinal "default: 0"
        uuid company_id FK "nullable"
        text company_accent "nullable"
        integer bullet_min
        integer bullet_max
    }

    generation_prompts {
        uuid id PK
        uuid generation_settings_id FK "unique"
        generation_scope scope UK
        text content
        timestamp created_at "default: now()"
        timestamp updated_at "default: now()"
    }

    generation_settings {
        uuid id PK
        uuid profile_id FK "unique"
        model_tier model_tier "default: balanced"
        integer bullet_min "default: 2"
        integer bullet_max "default: 5"
        timestamp created_at "default: now()"
        timestamp updated_at "default: now()"
    }

    job_descriptions {
        uuid id PK
        uuid company_id FK
        text title
        text description
        text url "nullable"
        text location "nullable"
        integer salary_min "nullable"
        integer salary_max "nullable"
        text salary_currency "nullable"
        job_level level "default: unknown"
        location_type location_type "default: unknown"
        job_source source
        timestamp posted_at "nullable"
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        text raw_text "nullable"
        bytea resume_pdf "nullable"
        text resume_pdf_theme "nullable"
        json sought_hard_skills "nullable"
        json sought_soft_skills "nullable"
    }

    profiles {
        uuid id PK
        timestamp created_at "default: CURRENT_TIMESTAMP"
        timestamp updated_at "default: CURRENT_TIMESTAMP"
        text email
        text first_name
        text last_name
        text phone "nullable"
        text location "nullable"
        text linkedin_url "nullable"
        text github_url "nullable"
        text website_url "nullable"
        text about "nullable"
    }

    resume_contents {
        uuid id PK
        uuid profile_id FK
        uuid job_description_id FK
        text headline
        json experiences
        text prompt
        json schema "nullable"
        timestamp created_at "default: now()"
        timestamp updated_at "default: now()"
        json hidden_education_ids "default: []"
    }

    %% ──────────────────────────────────────────────
    %%  Relationships
    %% ──────────────────────────────────────────────

    job_descriptions ||--o{ applications : "has"
    companies ||--o{ experiences : "has"
    job_descriptions ||--o{ resume_contents : "has"
    profiles ||--o{ resume_contents : "has"
    profiles ||--o{ applications : "has"
    profiles ||--o| generation_settings : "has"
    generation_settings ||--o| generation_prompts : "has"
    profiles ||--o{ experiences : "has"
    profiles ||--o{ educations : "has"
    profiles ||--o{ archetypes : "has"
    archetypes ||--o| archetype_tag_weights : "has"
    experiences ||--o{ accomplishments : "has"
    companies ||--o{ job_descriptions : "has"
    companies ||--o{ applications : "has"

    %% ──────────────────────────────────────────────
    %%  Styles
    %% ──────────────────────────────────────────────

    classDef group0 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    class accomplishments group0
    class applications group0
    class archetype_tag_weights group0
    class archetypes group0
    class companies group0
    class educations group0
    class experiences group0
    class generation_prompts group0
    class generation_settings group0
    class job_descriptions group0
    class profiles group0
    class resume_contents group0
