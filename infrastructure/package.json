{
  "name": "@tailoredin/infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "echo 'No unit tests — use test:integration for repository tests'",
    "test:coverage": "echo 'No unit tests'",
    "test:integration": "bun test test-integration/ --timeout 60000",
    "typecheck": "tsc --noEmit",
    "migration:create": "bunx mikro-orm migration:create",
    "migration:up": "bunx mikro-orm migration:up",
    "seed:run": "bunx mikro-orm seeder:run",
    "seed:run:e2e": "bunx mikro-orm seeder:run --class=E2eSeeder"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/db/orm-config.ts"
    ]
  },
  "dependencies": {
    "@mikro-orm/cli": "^7.0.0",
    "@mikro-orm/core": "^7.0.0",
    "@mikro-orm/decorators": "^7.0.0",
    "@mikro-orm/migrations": "^7.0.0",
    "@mikro-orm/postgresql": "^7.0.0",
    "@mikro-orm/reflection": "^7.0.0",
    "@mikro-orm/seeder": "^7.0.0",
    "@mikro-orm/sql-highlighter": "^1.0.1",
    "@needle-di/core": "^0.12.0",
    "@tailoredin/application": "workspace:*",
    "@tailoredin/core": "workspace:*",
    "@tailoredin/domain": "workspace:*",
    "@tselect/status-code": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "testcontainers": "^11.13.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.3"
  }
}
