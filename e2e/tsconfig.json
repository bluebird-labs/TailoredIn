{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@tailoredin/infrastructure/*": ["../infrastructure/src/*"],
      "@tailoredin/infrastructure": ["../infrastructure/src/index.ts"]
    }
  },
  "include": ["**/*.ts"]
}
