{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "core": {
      "entry": ["test/**/*.test.ts"]
    },
    "domain": {},
    "application": {},
    "infrastructure": {
      "entry": ["test-integration/**/*.test.ts", "test-integration/support/**", "dev/e2e-start-servers.ts"]
    },
    "api": {},
    "web": {
      "ignore": ["src/components/ui/**"]
    }
  },
  "ignore": ["e2e/**"],
  "ignoreBinaries": ["dot"],
  "ignoreDependencies": ["cmdk"],
  "exclude": ["nsExports", "nsTypes", "namespaceMembers", "duplicates"]
}
