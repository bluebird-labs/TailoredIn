{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "libs/core": {
      "entry": ["test/**/*.test.ts"]
    },
    "libs/domain": {},
    "libs/application": {},
    "libs/infrastructure": {
      "entry": [
        "test/**/*.test.ts",
        "test-integration/**/*.test.ts",
        "test-integration/support/**",
        "scripts/e2e-start-servers.ts",
        "src/db/migrations/*.ts",
        "src/db/seeds/**/*.ts"
      ]
    },
    "apps/api": {
      "ignoreDependencies": ["multer", "@nestjs/testing"]
    },
    "apps/web": {
      "entry": [
        "test/**/*.ts",
        "src/**/test/**/*.ts",
        "src/**/test/**/*.tsx",
        "src/components/shared/index.ts",
        "src/hooks/use-dirty-tracking.ts",
        "src/hooks/use-nav-guard.ts"
      ],
      "ignore": ["src/components/ui/**"]
    }
  },
  "ignore": ["apps/e2e/**", "jest.config.ts"],
  "ignoreBinaries": ["dot"],
  "ignoreDependencies": [],
  "exclude": ["nsExports", "nsTypes", "namespaceMembers", "duplicates", "enumMembers"]
}
