    %%  Experience Use Cases
    %% ──────────────────────────────────────────────

    class AddAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(AddAccomplishmentInput) Result<AccomplishmentDto, Error>
    }

    class CreateExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(CreateExperienceInput) ExperienceDto
    }

    class DeleteAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(DeleteAccomplishmentInput) Result<void, Error>
    }

    class DeleteExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(DeleteExperienceInput) Result<void, Error>
    }

    class GetExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +CompanyRepository companyRepository
        +execute(GetExperienceInput) ExperienceDto
    }

    class LinkCompanyToExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +CompanyRepository companyRepository
        +execute(LinkCompanyToExperienceInput) Result<ExperienceDto, Error>
    }

    class ListExperiences {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +CompanyRepository companyRepository
        +execute() ExperienceDto[]
    }

    class UnlinkCompanyFromExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(UnlinkCompanyFromExperienceInput) Result<ExperienceDto, Error>
    }

    class UpdateAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(UpdateAccomplishmentInput) Result<void, Error>
    }

    class UpdateExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(UpdateExperienceInput) Result<ExperienceDto, Error>
    }


    %% ──────────────────────────────────────────────
    %%  Job-description Use Cases
    %% ──────────────────────────────────────────────

    class CreateJobDescription {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(CreateJobDescriptionInput) JobDescriptionDto
    }

    class DeleteJobDescription {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(DeleteJobDescriptionInput) Result<void, Error>
    }

    class GetJobDescription {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +ResumeContentRepository resumeContentRepository
        +ExperienceRepository experienceRepository
        +execute(GetJobDescriptionInput) JobDescriptionDto
    }

    class ListJobDescriptions {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(ListJobDescriptionsInput) JobDescriptionDto[]
    }

    class ParseJobDescription {
        <<UseCase>>
        +JobDescriptionParser parser
        +execute(ParseJobDescriptionInput) JobDescriptionParseResult
    }

    class UpdateJobDescription {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(UpdateJobDescriptionInput) JobDescriptionDto
    }


    %% ──────────────────────────────────────────────
    %%  Profile Use Cases
    %% ──────────────────────────────────────────────

    class GetProfile {
        <<UseCase>>
        +ProfileRepository profileRepository
        +execute() ProfileDto
    }

    class UpdateProfile {
        <<UseCase>>
        +ProfileRepository profileRepository
        +execute(UpdateProfileInput) ProfileDto
    }


    %% ──────────────────────────────────────────────
    %%  Resume Use Cases
    %% ──────────────────────────────────────────────

    class CachedResumePdfResult {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(GetCachedResumePdfInput) CachedResumePdfResult | null
    }

    class GenerateResumeContent {
        <<UseCase>>
        +ProfileRepository profileRepository
        +ExperienceRepository experienceRepository
        +JobDescriptionRepository jobDescriptionRepository
        +ResumeContentRepository resumeContentRepository
        +ResumeContentGenerator generator
        +execute(GenerateResumeContentInput) ResumeContentDto
    }

    class GenerateResumeContentScope {
        <<UseCase>>
        +ProfileRepository profileRepository
        +ExperienceRepository experienceRepository
        +JobDescriptionRepository jobDescriptionRepository
        +ResumeContentRepository resumeContentRepository
        +ResumeContentGenerator generator
        +execute(GenerateResumeContentInput) ResumeContentDto
    }

    class GenerateResumeContentWithPdf {
        <<UseCase>>
        +GenerateResumeContent generateContent
        +GenerateResumePdf generatePdf
        +execute(GenerateResumeContentInput) ResumeContentDto
    }

    class GenerateResumePdf {
        <<UseCase>>
        +ProfileRepository profileRepository
        +ExperienceRepository experienceRepository
        +EducationRepository educationRepository
        +JobDescriptionRepository jobDescriptionRepository
        +ResumeContentRepository resumeContentRepository
        +ResumeRendererFactory rendererFactory
        +execute(GenerateResumePdfInput) Uint8Array
    }

    class GetCachedResumePdf {
        <<UseCase>>
        +JobDescriptionRepository jobDescriptionRepository
        +execute(GetCachedResumePdfInput) CachedResumePdfResult | null
    }

    class UpdateResumeDisplaySettings {
        <<UseCase>>
        +ResumeContentRepository resumeContentRepository
        +execute(UpdateResumeDisplaySettingsInput) void
    }

    GenerateResumeContentWithPdf ..> GenerateResumeContent : depends
    GenerateResumeContentWithPdf ..> GenerateResumePdf : depends

    %% ──────────────────────────────────────────────
    %%  Ports
    %% ──────────────────────────────────────────────

    class CompanyDataProvider {
        <<Port>>
        +enrichFromUrl(url, context?) Promise<CompanyEnrichmentResult>
    }

    class CompanyDiscoveryProvider {
        <<Port>>
        +discover(query) Promise<CompanyDiscoveryResult[]>
    }

    class JobDescriptionParser {
        <<Port>>
        +parseFromText(text) Promise<JobDescriptionParseResult>
    }

    class ResumeContentGenerator {
        <<Port>>
        +generate(input) Promise<ResumeContentGeneratorResult>
    }

    class ResumeRenderer {
        <<Port>>
        +render(input) Promise<Uint8Array>
    }

    class ResumeRendererFactory {
        <<Port>>
        +get(theme) ResumeRenderer
    }

    DiscoverCompanies ..> CompanyDiscoveryProvider : depends
    EnrichCompanyData ..> CompanyDataProvider : depends
    ParseJobDescription ..> JobDescriptionParser : depends
    GenerateResumeContentScope ..> ResumeContentGenerator : depends
    GenerateResumeContent ..> ResumeContentGenerator : depends
    GenerateResumePdf ..> ResumeRendererFactory : depends

    %% ──────────────────────────────────────────────
    %%  DTOs
    %% ──────────────────────────────────────────────

    class AccomplishmentDto {
        <<DTO>>
        +string id
        +string title
        +string narrative
        +number ordinal
    }

    class ApiErrorDto {
        <<DTO>>
        +object error
    }

    class ApplicationDto {
        <<DTO>>
        +string id
        +string profileId
        +string companyId
        +ApplicationStatus status
        +string? jobDescriptionId
        +string? notes
        +string appliedAt
        +string updatedAt
    }

    class CompanyDiscoveryResult {
        <<DTO>>
        +string name
        +string? website
        +string? description
    }

    class CompanyDto {
        <<DTO>>
        +string id
        +string name
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType? businessType
        +Industry? industry
        +CompanyStage? stage
        +CompanyStatus? status
    }

    class CompanyEnrichmentResult {
        <<DTO>>
        +string? name
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType? businessType
        +Industry? industry
        +CompanyStage? stage
        +CompanyStatus? status
    }

    class EducationDto {
        <<DTO>>
        +string id
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? location
        +string? honors
        +number ordinal
    }

    class ExperienceDto {
        <<DTO>>
        +string id
        +string title
        +string companyName
        +string? companyWebsite
        +string? companyId
        +CompanyDto? company
        +string location
        +string startDate
        +string endDate
        +string? summary
        +number ordinal
        +AccomplishmentDto[] accomplishments
    }

    class JobDescriptionDto {
        <<DTO>>
        +string id
        +string companyId
        +string title
        +string description
        +string? url
        +string? location
        +SalaryRangeDto? salaryRange
        +JobLevel? level
        +LocationType? locationType
        +JobSource source
        +string? postedAt
        +string createdAt
        +string updatedAt
        +string? rawText
        +string[]? soughtHardSkills
        +string[]? soughtSoftSkills
        +ResumeOutputDto? resumeOutput
        +boolean hasCachedPdf
        +string? resumePdfTheme
    }

    class JobDescriptionParseResult {
        <<DTO>>
        +string? title
        +string? description
        +string? url
        +string? location
        +number? salaryMin
        +number? salaryMax
        +string? salaryCurrency
        +JobLevel? level
        +LocationType? locationType
        +string? postedAt
        +string[]? soughtHardSkills
        +string[]? soughtSoftSkills
    }

    class PaginatedDto {
        <<DTO>>
        +T[] items
        +PaginationMeta pagination
    }

    class PaginationMeta {
        <<DTO>>
        +number limit
        +number offset
        +number total
        +boolean hasNext
    }

    class ProfileDto {
        <<DTO>>
        +string id
        +string email
        +string firstName
        +string lastName
        +string? about
        +string? phone
        +string? location
        +string? linkedinUrl
        +string? githubUrl
        +string? websiteUrl
    }

    class ResumeContentDto {
        <<DTO>>
        +string headline
        +ResumeExperienceBulletsDto[] experiences
    }

    class ResumeContentGeneratorExperience {
        <<DTO>>
        +string id
        +string title
        +string companyName
        +string? summary
        +object? accomplishments
        +number minBullets
        +number maxBullets
    }

    class ResumeContentGeneratorResult {
        <<DTO>>
        +string headline
        +object experiences
        +string requestPrompt
        +Record<string, unknown> requestSchema
    }

    class ResumeContentGeneratorScope {
        <<DTO>>
        +'headline' type
    }

    class ResumeExperienceBulletsDto {
        <<DTO>>
        +string experienceId
        +string experienceTitle
        +string companyName
        +string[] bullets
    }

    class ResumeOutputDto {
        <<DTO>>
        +string headline
        +Readonly{
    readonly experienceId: string;
    readonly experienceTitle: string;
    readonly companyName: string;
    readonly startDate: string;
    readonly endDate: string;
    readonly summary: string;
    readonly bullets: readonly string[];
    readonly displayedBulletCount: number;
  }[]? experiences
        +readonly string[] hiddenEducationIds
        +string generatedAt
    }

    class ResumeRenderEducation {
        <<DTO>>
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? location
        +string? honors
    }

    class ResumeRenderExperience {
        <<DTO>>
        +string title
        +string companyName
        +string location
        +string startDate
        +string? endDate
        +string? summary
        +string[] bullets
    }

    class SalaryRangeDto {
        <<DTO>>
        +number? min
        +number? max
        +string currency
    }

    ExperienceDto *-- CompanyDto
    ExperienceDto "1" *-- "*" AccomplishmentDto : contains
    JobDescriptionDto *-- SalaryRangeDto
    JobDescriptionDto *-- ResumeOutputDto
    PaginatedDto *-- PaginationMeta
    ResumeContentDto "1" *-- "*" ResumeExperienceBulletsDto : contains
