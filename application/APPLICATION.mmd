classDiagram
    direction TB

    %% ──────────────────────────────────────────────
    %%  Application Use Cases
    %% ──────────────────────────────────────────────

    class CreateApplication {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(CreateApplicationInput) ApplicationDto
    }

    class DeleteApplication {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(DeleteApplicationInput) Result<void, Error>
    }

    class GetApplication {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(GetApplicationInput) ApplicationDto
    }

    class ListApplications {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(ListApplicationsInput) ApplicationDto[]
    }

    class UpdateApplication {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(UpdateApplicationInput) ApplicationDto
    }

    class UpdateApplicationStatus {
        <<UseCase>>
        +ApplicationRepository applicationRepository
        +execute(UpdateApplicationStatusInput) ApplicationDto
    }


    %% ──────────────────────────────────────────────
    %%  Company Use Cases
    %% ──────────────────────────────────────────────

    class CreateCompany {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute(CreateCompanyInput) CompanyDto
    }

    class DiscoverCompanies {
        <<UseCase>>
        +CompanyDiscoveryProvider discoveryProvider
        +execute(DiscoverCompaniesInput) CompanyDiscoveryResult[]
    }

    class EnrichCompanyData {
        <<UseCase>>
        +CompanyDataProvider companyDataProvider
        +execute(EnrichCompanyDataInput) CompanyEnrichmentResult
    }

    class GetCompany {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute(GetCompanyInput) CompanyDto
    }

    class ListCompanies {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute() CompanyDto[]
    }

    class UpdateCompany {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute(UpdateCompanyInput) CompanyDto
    }


    %% ──────────────────────────────────────────────
    %%  Education Use Cases
    %% ──────────────────────────────────────────────

    class CreateEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(CreateEducationInput) EducationDto
    }

    class DeleteEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(DeleteEducationInput) Result<void, Error>
    }

    class ListEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute() EducationDto[]
    }

    class UpdateEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(UpdateEducationInput) Result<EducationDto, Error>
    }


