---
title: TailoredIn — Application Layer (Use Cases, Ports, DTOs)
---

classDiagram
    direction TB

    %% ──────────────────────────────────────────────
    %%  Company Use Cases
    %% ──────────────────────────────────────────────

    class CreateCompany {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute(CreateCompanyInput) CompanyDto
    }

    class EnrichCompanyData {
        <<UseCase>>
        +CompanyDataProvider companyDataProvider
        +execute(EnrichCompanyDataInput) CompanyEnrichmentResult
    }

    class ListCompanies {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute() CompanyDto[]
    }

    class SearchCompanies {
        <<UseCase>>
        +CompanySearchProvider searchProvider
        +execute(SearchCompaniesInput) CompanySearchResult[]
    }

    class UpdateCompany {
        <<UseCase>>
        +CompanyRepository companyRepository
        +execute(UpdateCompanyInput) CompanyDto
    }


    %% ──────────────────────────────────────────────
    %%  Education Use Cases
    %% ──────────────────────────────────────────────

    class CreateEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(CreateEducationInput) EducationDto
    }

    class DeleteEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(DeleteEducationInput) Result<void, Error>
    }

    class ListEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute() EducationDto[]
    }

    class UpdateEducation {
        <<UseCase>>
        +EducationRepository educationRepository
        +execute(UpdateEducationInput) Result<EducationDto, Error>
    }


    %% ──────────────────────────────────────────────
    %%  Experience Use Cases
    %% ──────────────────────────────────────────────

    class AddAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(AddAccomplishmentInput) Result<AccomplishmentDto, Error>
    }

    class CreateExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(CreateExperienceInput) ExperienceDto
    }

    class DeleteAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(DeleteAccomplishmentInput) Result<void, Error>
    }

    class DeleteExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(DeleteExperienceInput) Result<void, Error>
    }

    class ListExperiences {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute() ExperienceDto[]
    }

    class UpdateAccomplishment {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(UpdateAccomplishmentInput) Result<void, Error>
    }

    class UpdateExperience {
        <<UseCase>>
        +ExperienceRepository experienceRepository
        +execute(UpdateExperienceInput) Result<ExperienceDto, Error>
    }


    %% ──────────────────────────────────────────────
    %%  Headline Use Cases
    %% ──────────────────────────────────────────────

    class CreateHeadline {
        <<UseCase>>
        +HeadlineRepository headlineRepository
        +execute(CreateHeadlineInput) HeadlineDto
    }

    class DeleteHeadline {
        <<UseCase>>
        +HeadlineRepository headlineRepository
        +execute(DeleteHeadlineInput) Result<void, Error>
    }

    class ListHeadlines {
        <<UseCase>>
        +HeadlineRepository headlineRepository
        +execute() HeadlineDto[]
    }

    class UpdateHeadline {
        <<UseCase>>
        +HeadlineRepository headlineRepository
        +execute(UpdateHeadlineInput) Result<HeadlineDto, Error>
    }


    %% ──────────────────────────────────────────────
    %%  Profile Use Cases
    %% ──────────────────────────────────────────────

    class GetProfile {
        <<UseCase>>
        +ProfileRepository profileRepository
        +execute() ProfileDto
    }

    class UpdateProfile {
        <<UseCase>>
        +ProfileRepository profileRepository
        +execute(UpdateProfileInput) ProfileDto
    }


    %% ──────────────────────────────────────────────
    %%  Ports
    %% ──────────────────────────────────────────────

    class CompanyDataProvider {
        <<Port>>
        +enrichFromUrl(url, context?) Promise<CompanyEnrichmentResult>
    }

    class CompanySearchProvider {
        <<Port>>
        +searchByName(name) Promise<CompanySearchResult[]>
    }

    EnrichCompanyData ..> CompanyDataProvider : depends
    SearchCompanies ..> CompanySearchProvider : depends

    %% ──────────────────────────────────────────────
    %%  DTOs
    %% ──────────────────────────────────────────────

    class AccomplishmentDto {
        <<DTO>>
        +string id
        +string title
        +string narrative
        +number ordinal
    }

    class ApiErrorDto {
        <<DTO>>
        +object error
    }

    class CompanyDto {
        <<DTO>>
        +string id
        +string name
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType? businessType
        +Industry? industry
        +CompanyStage? stage
    }

    class CompanyEnrichmentResult {
        <<DTO>>
        +string? name
        +string? description
        +string? website
        +string? logoUrl
        +string? linkedinLink
        +BusinessType? businessType
        +Industry? industry
        +CompanyStage? stage
    }

    class CompanySearchResult {
        <<DTO>>
        +string name
        +string? website
        +string? description
    }

    class EducationDto {
        <<DTO>>
        +string id
        +string degreeTitle
        +string institutionName
        +number graduationYear
        +string? location
        +string? honors
        +number ordinal
    }

    class ExperienceDto {
        <<DTO>>
        +string id
        +string title
        +string companyName
        +string? companyWebsite
        +string location
        +string startDate
        +string endDate
        +string? summary
        +number ordinal
        +AccomplishmentDto[] accomplishments
    }

    class HeadlineDto {
        <<DTO>>
        +string id
        +string label
        +string summaryText
    }

    class PaginatedDto {
        <<DTO>>
        +T[] items
        +PaginationMeta pagination
    }

    class PaginationMeta {
        <<DTO>>
        +number limit
        +number offset
        +number total
        +boolean hasNext
    }

    class ProfileDto {
        <<DTO>>
        +string id
        +string email
        +string firstName
        +string lastName
        +string? about
        +string? phone
        +string? location
        +string? linkedinUrl
        +string? githubUrl
        +string? websiteUrl
    }

    ExperienceDto "1" *-- "*" AccomplishmentDto : contains
    PaginatedDto *-- PaginationMeta
    CompanyDataProvider ..> CompanyEnrichmentResult : produces
    CompanySearchProvider ..> CompanySearchResult : produces
    CreateCompany ..> CompanyDto : returns
    EnrichCompanyData ..> CompanyEnrichmentResult : returns
    ListCompanies ..> CompanyDto : returns
    SearchCompanies ..> CompanySearchResult : returns
    UpdateCompany ..> CompanyDto : returns
    CreateEducation ..> EducationDto : returns
    ListEducation ..> EducationDto : returns
    UpdateEducation ..> EducationDto : returns
    AddAccomplishment ..> AccomplishmentDto : returns
    CreateExperience ..> ExperienceDto : returns
    ListExperiences ..> ExperienceDto : returns
    UpdateExperience ..> ExperienceDto : returns
    GetProfile ..> ProfileDto : returns
    CreateHeadline ..> HeadlineDto : returns
    ListHeadlines ..> HeadlineDto : returns
    UpdateHeadline ..> HeadlineDto : returns
    UpdateProfile ..> ProfileDto : returns

    %% ──────────────────────────────────────────────
    %%  Errors
    %% ──────────────────────────────────────────────

    class ExternalServiceError {
        <<Error>>
        +number statusCode
        +string code
        +constructor(service, message)
    }


    %% ──────────────────────────────────────────────
    %%  Domain Ports (external)
    %% ──────────────────────────────────────────────

    class CompanyRepository {
        <<DomainPort>>
    }

    class EducationRepository {
        <<DomainPort>>
    }

    class ExperienceRepository {
        <<DomainPort>>
    }

    class HeadlineRepository {
        <<DomainPort>>
    }

    class ProfileRepository {
        <<DomainPort>>
    }

    CreateCompany ..> CompanyRepository : depends
    ListCompanies ..> CompanyRepository : depends
    UpdateCompany ..> CompanyRepository : depends
    CreateEducation ..> EducationRepository : depends
    DeleteEducation ..> EducationRepository : depends
    ListEducation ..> EducationRepository : depends
    UpdateEducation ..> EducationRepository : depends
    AddAccomplishment ..> ExperienceRepository : depends
    CreateExperience ..> ExperienceRepository : depends
    DeleteAccomplishment ..> ExperienceRepository : depends
    DeleteExperience ..> ExperienceRepository : depends
    ListExperiences ..> ExperienceRepository : depends
    UpdateAccomplishment ..> ExperienceRepository : depends
    UpdateExperience ..> ExperienceRepository : depends
    GetProfile ..> ProfileRepository : depends
    CreateHeadline ..> HeadlineRepository : depends
    DeleteHeadline ..> HeadlineRepository : depends
    ListHeadlines ..> HeadlineRepository : depends
    UpdateHeadline ..> HeadlineRepository : depends
    UpdateProfile ..> ProfileRepository : depends

