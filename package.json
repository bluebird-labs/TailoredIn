{
  "name": "tailoredin",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@jest/globals": "^30.3.0",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "dependency-cruiser": "^17",
    "jest": "^30.3.0",
    "knip": "^6.1.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.19.0",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "dev:up": "tsx infrastructure/scripts/dev-env.ts",
    "dev:down": "tsx infrastructure/scripts/dev-down.ts",
    "dev:fresh": "pnpm run dev:down -- --clean && pnpm run dev:up",
    "dev": "turbo run dev",
    "dev:docker": "tsx infrastructure/scripts/dev-docker.ts",
    "dev:migrate": "turbo run dev:migrate --filter=@tailoredin/infrastructure",
    "dev:seed": "turbo run dev:seed --filter=@tailoredin/infrastructure",
    "dev:migration:create": "pnpm --filter @tailoredin/infrastructure run migration:create",
    "dev:set-password": "tsx infrastructure/scripts/set-password.ts",
    "web:dev": "pnpm --filter @tailoredin/web run dev",
    "web:build": "pnpm --filter @tailoredin/web run build",
    "web:storybook": "pnpm --filter @tailoredin/web run storybook",
    "web:storybook:build": "pnpm --filter @tailoredin/web run storybook:build",
    "check": "biome check domain application infrastructure core api web",
    "check:fix": "biome check --write domain application infrastructure core api web",
    "format": "biome format --write domain application infrastructure core api web",
    "lint": "biome lint domain application infrastructure core api web",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "knip": "knip",
    "dep:check": "depcruise domain application infrastructure api web --config .dependency-cruiser.cjs",
    "dep:graph": "depcruise domain application infrastructure api web --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dep-graph.svg",
    "e2e:test": "pnpm --filter @tailoredin/e2e run test",
    "e2e:test:ui": "pnpm --filter @tailoredin/e2e run test:ui",
    "e2e:test:headed": "pnpm --filter @tailoredin/e2e run test:headed",
    "db:seed:generate-types": "tsx infrastructure/src/db/generate-seed-types.ts",
    "domain:diagram": "tsx scripts/diagrams/domain/generate.ts",
    "app:diagram": "tsx scripts/diagrams/application/generate.ts",
    "db:diagram": "tsx scripts/diagrams/database/generate.ts",
    "diags": "turbo run domain:diagram app:diagram db:diagram",
    "esco:import": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/esco-import.ts",
    "linguist:import": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/linguist-import.ts",
    "mind:import": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/mind-import.ts",
    "tanova:import": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/tanova-import.ts",
    "skills:sync": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/skills-sync.ts",
    "skills:reset": "node --env-file=.env.local --import tsx/esm infrastructure/scripts/skills-reset.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "argon2",
      "better-sqlite3",
      "cpu-features",
      "esbuild",
      "msw",
      "protobufjs",
      "ssh2",
      "unrs-resolver"
    ]
  },
  "workspaces": [
    "domain",
    "application",
    "infrastructure",
    "core",
    "api",
    "web",
    "e2e"
  ]
}
