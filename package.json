{
  "name": "tailoredin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend": "bun run --cwd packages/api src/index.ts",
    "backend:watch": "bun --watch --cwd packages/api src/index.ts",
    "robot": "bun run --cwd packages/robot src/index.ts",
    "robot:watch": "bun --watch --cwd packages/robot src/index.ts",
    "cvs": "bun run --cwd packages/resume cli/index.ts",

    "lint": "biome check packages",
    "lint:fix": "biome check --write packages",
    "format": "biome format --write packages",
    "typecheck": "bun run --filter '@tailoredin/*' typecheck",
    "test": "bun run --filter '@tailoredin/*' test",
    "test:coverage": "bun run --filter '@tailoredin/*' test:coverage",

    "shared:lint": "biome check packages/shared",
    "shared:lint:fix": "biome check --write packages/shared",
    "shared:typecheck": "bun run --cwd packages/shared typecheck",
    "shared:test": "bun run --cwd packages/shared test",
    "shared:test:coverage": "bun run --cwd packages/shared test:coverage",

    "db:lint": "biome check packages/db",
    "db:lint:fix": "biome check --write packages/db",
    "db:typecheck": "bun run --cwd packages/db typecheck",
    "db:test": "bun run --cwd packages/db test",
    "db:test:coverage": "bun run --cwd packages/db test:coverage",
    "db:sql": "bun run --cwd packages/db sql",
    "db:sql:watch": "bun run --cwd packages/db sql:watch",
    "db:migration:create": "bun run --cwd packages/db migration:create",
    "db:migration:up": "bun run --cwd packages/db migration:up",

    "ai:lint": "biome check packages/ai",
    "ai:lint:fix": "biome check --write packages/ai",
    "ai:typecheck": "bun run --cwd packages/ai typecheck",
    "ai:test": "bun run --cwd packages/ai test",
    "ai:test:coverage": "bun run --cwd packages/ai test:coverage",

    "linkedin:lint": "biome check packages/linkedin",
    "linkedin:lint:fix": "biome check --write packages/linkedin",
    "linkedin:typecheck": "bun run --cwd packages/linkedin typecheck",
    "linkedin:test": "bun run --cwd packages/linkedin test",
    "linkedin:test:coverage": "bun run --cwd packages/linkedin test:coverage",

    "resume:lint": "biome check packages/resume",
    "resume:lint:fix": "biome check --write packages/resume",
    "resume:typecheck": "bun run --cwd packages/resume typecheck",
    "resume:test": "bun run --cwd packages/resume test",
    "resume:test:coverage": "bun run --cwd packages/resume test:coverage",

    "api:lint": "biome check packages/api",
    "api:lint:fix": "biome check --write packages/api",
    "api:typecheck": "bun run --cwd packages/api typecheck",
    "api:test": "bun run --cwd packages/api test",
    "api:test:coverage": "bun run --cwd packages/api test:coverage",

    "robot:lint": "biome check packages/robot",
    "robot:lint:fix": "biome check --write packages/robot",
    "robot:typecheck": "bun run --cwd packages/robot typecheck",
    "robot:test": "bun run --cwd packages/robot test",
    "robot:test:coverage": "bun run --cwd packages/robot test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "latest"
  }
}
