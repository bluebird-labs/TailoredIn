{
  "name": "tailoredin",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "latest",
    "bun-types": "^1.3.11",
    "dependency-cruiser": "^17",
    "knip": "^6.1.0",
    "ts-morph": "^27.0.2",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "api": "bun run api/src/index.ts",
    "api:dev": "bun --env-file=${BUN_ENV_FILE:-.env} --watch api/src/index.ts",
    "dev": "bun run --parallel api:dev web:dev",
    "web": "bun run --cwd web preview",
    "web:dev": "bun --env-file=${BUN_ENV_FILE:-.env} run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "web:storybook": "bun run --cwd web storybook",
    "web:storybook:build": "bun run --cwd web storybook:build",
    "check": "biome check domain application infrastructure core api web",
    "check:fix": "biome check --write domain application infrastructure core api web",
    "format": "biome format --write domain application infrastructure core api web",
    "lint": "biome lint domain application infrastructure core api web",
    "typecheck": "bun run --filter '@tailoredin/*' typecheck",
    "test": "bun run --filter '@tailoredin/*' test",
    "test:coverage": "bun run --filter '@tailoredin/*' test:coverage",
    "knip": "knip",
    "dep:check": "depcruise domain application infrastructure api web --config .dependency-cruiser.cjs",
    "dep:graph": "depcruise domain application infrastructure api web --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dep-graph.svg",
    "api:lint": "biome check api",
    "api:lint:fix": "biome check --write api",
    "api:typecheck": "bun run --cwd api typecheck",
    "api:test": "bun run --cwd api test",
    "dev:up": "bun --env-file=.env run infrastructure/scripts/dev-up.ts",
    "dev:down": "bun --env-file=.env run infrastructure/scripts/dev-down.ts",
    "dev:fresh": "bun dev:down && bun dev:up",
    "dev:migration:create": "bun run infrastructure/scripts/guard-main.ts && bun --env-file=.env run --cwd infrastructure migration:create",
    "dev:migration:up": "bun run infrastructure/scripts/guard-main.ts && bun --env-file=.env run --cwd infrastructure migration:up",
    "dev:seed": "bun run infrastructure/scripts/guard-main.ts && bun --env-file=.env run --cwd infrastructure seed:run",
    "dev:set-password": "bun run infrastructure/scripts/guard-main.ts && bun --env-file=.env run infrastructure/scripts/set-password.ts",
    "dev:diagram": "bun run infrastructure/scripts/guard-main.ts && bun run scripts/diagrams/database/generate.ts",
    "wt:up": "bun run infrastructure/scripts/wt-up.ts",
    "wt:down": "bun run infrastructure/scripts/wt-down.ts",
    "wt:fresh": "bun wt:down && bun wt:up",
    "wt:migration:up": "bun run infrastructure/scripts/wt-migration-up.ts",
    "wt:seed": "bun run infrastructure/scripts/wt-seed.ts",
    "wt:set-password": "bun run infrastructure/scripts/set-password.ts",
    "e2e:test": "bun run --cwd e2e test",
    "e2e:test:ui": "bun run --cwd e2e test:ui",
    "e2e:test:headed": "bun run --cwd e2e test:headed",
    "db:seed:generate-types": "bun --env-file=.env run infrastructure/src/db/generate-seed-types.ts",
    "domain:diagram": "bun run scripts/diagrams/domain/generate.ts",
    "app:diagram": "bun run scripts/diagrams/application/generate.ts",
    "db:diagram": "bun run scripts/diagrams/database/generate.ts",
    "diags": "bun run --parallel db:diagram app:diagram domain:diagram",
    "esco:import": "bun --env-file=.env run infrastructure/scripts/esco-import.ts",
    "linguist:import": "bun --env-file=.env run infrastructure/scripts/linguist-import.ts",
    "mind:import": "bun --env-file=.env run infrastructure/scripts/mind-import.ts",
    "tanova:import": "bun --env-file=.env run infrastructure/scripts/tanova-import.ts",
    "skills:sync": "bun --env-file=.env run infrastructure/scripts/skills-sync.ts",
    "skills:reset": "bun --env-file=.env run infrastructure/scripts/skills-reset.ts",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:test": "turbo run test",
    "turbo:check": "turbo run check"
  },
  "workspaces": [
    "domain",
    "application",
    "infrastructure",
    "core",
    "api",
    "web",
    "e2e"
  ]
}
