{
  "name": "tailoredin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "domain",
    "application",
    "infrastructure",
    "core",
    "presentation/*"
  ],
  "scripts": {
    "backend": "bun run --cwd presentation/api src/index.ts",
    "backend:watch": "bun --watch --cwd presentation/api src/index.ts",
    "robot": "bun run --cwd presentation/cli src/robot/index.ts",
    "robot:watch": "bun --watch --cwd presentation/cli src/robot/index.ts",
    "cvs": "bun run --cwd presentation/cli src/cvs/index.ts",

    "check": "biome check domain application infrastructure shared presentation",
    "check:fix": "biome check --write domain application infrastructure shared presentation",
    "format": "biome format --write domain application infrastructure shared presentation",
    "lint": "biome lint domain application infrastructure shared presentation",
    "typecheck": "bun run --filter '@tailoredin/*' typecheck",
    "test": "bun run --filter '@tailoredin/*' test",
    "test:coverage": "bun run --filter '@tailoredin/*' test:coverage",

    "dep:check": "depcruise domain application infrastructure presentation --config .dependency-cruiser.cjs",
    "dep:graph": "depcruise domain application infrastructure presentation --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dep-graph.svg",

    "api:lint": "biome check presentation/api",
    "api:lint:fix": "biome check --write presentation/api",
    "api:typecheck": "bun run --cwd presentation/api typecheck",
    "api:test": "bun run --cwd presentation/api test",

    "cli:lint": "biome check presentation/cli",
    "cli:lint:fix": "biome check --write presentation/cli",
    "cli:typecheck": "bun run --cwd presentation/cli typecheck",
    "cli:test": "bun run --cwd presentation/cli test",

    "db:migration:create": "bun run --cwd infrastructure migration:create",
    "db:migration:up": "bun run --cwd infrastructure migration:up"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "dependency-cruiser": "^17"
  }
}
