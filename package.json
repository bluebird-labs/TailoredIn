{
  "name": "tailoredin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend": "bun run --cwd packages/api src/index.ts",
    "backend:watch": "bun --watch --cwd packages/api src/index.ts",
    "robot": "bun run --cwd packages/robot src/index.ts",
    "robot:watch": "bun --watch --cwd packages/robot src/index.ts",
    "cvs": "bun run --cwd packages/resume cli/index.ts",
    "check": "biome check packages",
    "check:fix": "biome check --write packages",
    "format": "biome format --write packages",
    "lint": "biome lint packages",
    "typecheck": "for dir in packages/*/; do bun run --cwd \"$dir\" typecheck 2>/dev/null; done"
  },
  "devDependencies": {
    "@biomejs/biome": "latest"
  }
}
